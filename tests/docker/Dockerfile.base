# Base Dockerfile for Cicada testing
# Minimal Python environment with uv and cicada source
# Uses `uv run` to execute cicada without installing dependencies

FROM python:3.11-slim

# Install system dependencies (git is required by Cicada)
RUN apt-get update && apt-get install -y \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install uv
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:$PATH"

# Copy Cicada source
WORKDIR /cicada
COPY . .

# Don't install - just use `uv run cicada` which will install on demand

WORKDIR /workspace

CMD ["/bin/bash"]
